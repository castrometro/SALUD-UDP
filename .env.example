# ============================================
# SALUD-UDP — Variables de entorno (desarrollo)
# ============================================
# Copiar este archivo:  cp .env.example .env
# No se necesita cambiar nada para correr local.

# --- Base de Datos (MySQL) ---
MYSQL_DATABASE=dbficha_dev
MYSQL_USER=dev_user
MYSQL_PASSWORD=dev_password
MYSQL_ROOT_PASSWORD=root_password
DB_HOST=db
DB_PORT=3306

# --- Backend (Django) ---
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-local-dev-key-change-in-prod

# --- Superusuario inicial ---
DJANGO_SUPERUSER_EMAIL=admin@admin.com
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=Sistema

# --- Frontend (Vite) ---
# Solo necesario si el frontend NO usa el proxy de Vite/Nginx.
# En Docker con docker-compose, el proxy se encarga y esta variable no es necesaria.
# VITE_API_URL=/api
